+inline bool env_truthy(char const* name) {
+  char const* value = std::getenv(name);
+  if (value == nullptr) {
+    return false;
+  }
+  return std::strcmp(value, "1") == 0 || std::strcmp(value, "true") == 0 ||
+         std::strcmp(value, "TRUE") == 0 || std::strcmp(value, "yes") == 0 ||
+         std::strcmp(value, "YES") == 0 || std::strcmp(value, "on") == 0 ||
+         std::strcmp(value, "ON") == 0;
+}
+
+inline void log_cuda_active_marker_once(char const* variant, int num_tokens) {
+  if (!env_truthy("SGLANG_KIMI_WARP_DECODE_MARK_ACTIVE")) {
+    return;
+  }
+  static bool row_major_logged = false;
+  static bool tiled_down_logged = false;
+  bool& logged = std::strcmp(variant, "tiled-W_down") == 0 ? tiled_down_logged : row_major_logged;
+  if (logged) {
+    return;
+  }
+  logged = true;
+  std::cerr << "SGLANG_KIMI_WARP_DECODE_CUDA_ACTIVE variant=" << variant
+            << " num_tokens=" << num_tokens << std::endl;
+}
