+Array<Tensor> kimi_k26_mxint4_warp_decode_moe(
+    TensorView routing_logits, Optional<TensorView> routing_bias, TensorView hidden_states,
+    TensorView gemm1_weights, TensorView gemm1_weights_scale, Optional<TensorView> gemm1_alpha,
+    Optional<TensorView> gemm1_beta, Optional<TensorView> gemm1_clamp_limit,
+    TensorView gemm2_weights, TensorView gemm2_weights_scale, int64_t num_experts, int64_t top_k,
+    Optional<int64_t> n_group, Optional<int64_t> topk_group, int64_t intermediate_size,
+    int64_t local_expert_offset, int64_t local_num_experts, Optional<double> routed_scaling_factor,
+    int64_t routing_method_type, Optional<TensorView> output) {
+  using namespace kimi_k26_warp_decode;
+
+  int const num_tokens = hidden_states.size(0);
+  int const hidden_size = hidden_states.size(1);
+  int const intermediate = static_cast<int>(intermediate_size);
+  int const local_experts = static_cast<int>(local_num_experts);
+
+  TVM_FFI_ICHECK_EQ(hidden_states.ndim(), 2) << "hidden_states must be 2D.";
+  TVM_FFI_ICHECK_EQ(hidden_states.dtype(), dl_bfloat16) << "hidden_states must be bf16.";
+  TVM_FFI_ICHECK(routing_logits.dtype() == dl_float32 || routing_logits.dtype() == dl_bfloat16)
+      << "routing_logits must be float or bfloat16.";
+  TVM_FFI_ICHECK_EQ(routing_logits.ndim(), 2) << "routing_logits must be 2D.";
+  TVM_FFI_ICHECK_EQ(routing_logits.size(0), num_tokens)
+      << "routing_logits and hidden_states must have the same number of tokens.";
+  TVM_FFI_ICHECK_EQ(routing_logits.size(1), num_experts)
+      << "routing_logits dim1 must match num_experts.";
+  if (routing_bias.has_value()) {
+    TVM_FFI_ICHECK_EQ(routing_bias.value().dtype(), dl_bfloat16)
+        << "routing_bias must be bfloat16.";
+    TVM_FFI_ICHECK_EQ(routing_bias.value().ndim(), 1) << "routing_bias must be 1D.";
+    TVM_FFI_ICHECK_EQ(routing_bias.value().size(0), num_experts)
+        << "routing_bias has incorrect shape.";
+  }
+  TVM_FFI_ICHECK_EQ(gemm1_weights.dtype(), dl_uint8) << "gemm1_weights must be uint8.";
+  TVM_FFI_ICHECK_EQ(gemm2_weights.dtype(), dl_uint8) << "gemm2_weights must be uint8.";
+  TVM_FFI_ICHECK_EQ(gemm1_weights_scale.dtype(), dl_bfloat16)
+      << "gemm1_weights_scale must be bf16.";
+  TVM_FFI_ICHECK_EQ(gemm2_weights_scale.dtype(), dl_bfloat16)
+      << "gemm2_weights_scale must be bf16.";
+
+  TVM_FFI_ICHECK_EQ(top_k, 8) << "kimi_k26_mxint4_warp_decode_moe supports top_k=8 only.";
+  TVM_FFI_ICHECK_EQ(num_experts, 384)
+      << "kimi_k26_mxint4_warp_decode_moe supports num_experts=384 only.";
+  TVM_FFI_ICHECK_EQ(hidden_size, 7168)
+      << "kimi_k26_mxint4_warp_decode_moe supports hidden_size=7168 only.";
+  TVM_FFI_ICHECK_EQ(intermediate, kKimiK26IntermediateSize)
+      << "kimi_k26_mxint4_warp_decode_moe supports intermediate_size="
+      << kKimiK26IntermediateSize << " only.";
+  TVM_FFI_ICHECK_EQ(n_group.value_or(1), 1)
+      << "kimi_k26_mxint4_warp_decode_moe supports n_group=1 only.";
+  TVM_FFI_ICHECK_EQ(topk_group.value_or(1), 1)
+      << "kimi_k26_mxint4_warp_decode_moe supports topk_group=1 only.";
+  TVM_FFI_ICHECK(routing_method_type == static_cast<int64_t>(RoutingMethodType::DeepSeekV3))
+      << "kimi_k26_mxint4_warp_decode_moe supports DeepSeekV3/Kimi biased sigmoid top-k only.";
+  TVM_FFI_ICHECK_EQ(local_expert_offset, 0)
+      << "kimi_k26_mxint4_warp_decode_moe v1 supports local_expert_offset=0 only.";
+  TVM_FFI_ICHECK_EQ(local_num_experts, num_experts)
+      << "kimi_k26_mxint4_warp_decode_moe v1 requires all routed experts to be local.";
+  TVM_FFI_ICHECK(!gemm1_alpha.has_value() && !gemm1_beta.has_value() &&
+                 !gemm1_clamp_limit.has_value())
+      << "kimi_k26_mxint4_warp_decode_moe v1 does not support per-expert SwiGLU "
+         "alpha/beta/clamp tensors.";
+
+  TVM_FFI_ICHECK_EQ(gemm1_weights.ndim(), 3) << "gemm1_weights must be 3D row-major.";
+  TVM_FFI_ICHECK_EQ(gemm1_weights.size(0), local_experts);
+  TVM_FFI_ICHECK_EQ(gemm1_weights.size(1), 2 * intermediate);
+  TVM_FFI_ICHECK_EQ(gemm1_weights.size(2), hidden_size / 2);
+  TVM_FFI_ICHECK_EQ(gemm1_weights_scale.ndim(), 3) << "gemm1_weights_scale must be 3D.";
+  TVM_FFI_ICHECK_EQ(gemm1_weights_scale.size(0), local_experts);
+  TVM_FFI_ICHECK_EQ(gemm1_weights_scale.size(1), 2 * intermediate);
+  TVM_FFI_ICHECK_EQ(gemm1_weights_scale.size(2), hidden_size / kMxInt4GroupSize);
+  TVM_FFI_ICHECK_EQ(gemm2_weights.ndim(), 3) << "gemm2_weights must be 3D row-major.";
+  TVM_FFI_ICHECK_EQ(gemm2_weights.size(0), local_experts);
+  TVM_FFI_ICHECK_EQ(gemm2_weights.size(1), hidden_size);
+  TVM_FFI_ICHECK_EQ(gemm2_weights.size(2), intermediate / 2);
+  TVM_FFI_ICHECK_EQ(gemm2_weights_scale.ndim(), 3) << "gemm2_weights_scale must be 3D.";
+  TVM_FFI_ICHECK_EQ(gemm2_weights_scale.size(0), local_experts);
+  TVM_FFI_ICHECK_EQ(gemm2_weights_scale.size(1), hidden_size);
+  TVM_FFI_ICHECK_EQ(gemm2_weights_scale.size(2), intermediate / kMxInt4GroupSize);
+
+  Tensor output_tensor;
+  void* output_ptr = nullptr;
+  if (output.has_value()) {
+    TVM_FFI_ICHECK_EQ(output.value().dtype(), dl_bfloat16) << "output must be bf16.";
+    TVM_FFI_ICHECK_EQ(output.value().ndim(), 2) << "output must be 2D.";
+    TVM_FFI_ICHECK_EQ(output.value().size(0), num_tokens);
+    TVM_FFI_ICHECK_EQ(output.value().size(1), hidden_size);
+    output_ptr = output.value().data_ptr();
+  } else {
+    output_tensor = alloc_tensor({num_tokens, hidden_size}, dl_bfloat16, hidden_states.device());
+    output_ptr = output_tensor.data_ptr();
+  }
+  if (num_tokens == 0) {
+    if (output.has_value()) {
+      return Array<Tensor>();
+    }
+    return {output_tensor};
+  }
+
+  auto topk_ids = alloc_tensor({num_tokens, kKimiTopK}, dl_int32, hidden_states.device());
+  auto topk_weights = alloc_tensor({num_tokens, kKimiTopK}, dl_float32,
+                                   hidden_states.device());
+  auto intermediate_tensor =
+      alloc_tensor({num_tokens, kKimiTopK, kKimiK26IntermediateSize}, dl_bfloat16,
+                   hidden_states.device());
+
+  log_cuda_active_marker_once("row-major", num_tokens);
+
+  cudaStream_t stream = get_stream(hidden_states.device());
+  bool const routing_logits_is_bf16 = routing_logits.dtype() == dl_bfloat16;
+  float const scaling = static_cast<float>(routed_scaling_factor.value_or(1.0));
+  int const topk_threads = 128;
+  int const topk_blocks = (num_tokens + topk_threads - 1) / topk_threads;
+  kimi_k26_topk_deepseek_v3_kernel<<<topk_blocks, topk_threads, 0, stream>>>(
+      routing_logits.data_ptr(), routing_logits_is_bf16,
+      routing_bias.has_value()
+          ? reinterpret_cast<__nv_bfloat16 const*>(routing_bias.value().data_ptr())
+          : nullptr,
+      static_cast<int32_t*>(topk_ids.data_ptr()), static_cast<float*>(topk_weights.data_ptr()),
+      num_tokens, kKimiNumExperts, kKimiTopK, scaling);
+  check_cuda_launch("kimi_k26_topk_deepseek_v3_kernel");
+
+  dim3 gate_up_grid(kGateUpCtasPerToken, num_tokens);
+  kimi_k26_moe_gate_up_warp_decode_kernel<<<gate_up_grid, kThreadsPerCta, 0, stream>>>(
+      reinterpret_cast<__nv_bfloat16 const*>(hidden_states.data_ptr()),
+      static_cast<uint8_t const*>(gemm1_weights.data_ptr()),
+      reinterpret_cast<__nv_bfloat16 const*>(gemm1_weights_scale.data_ptr()),
+      static_cast<int32_t const*>(topk_ids.data_ptr()),
+      reinterpret_cast<__nv_bfloat16*>(intermediate_tensor.data_ptr()), num_tokens,
+      kKimiTopK, kKimiHiddenSize, kKimiK26IntermediateSize,
+      static_cast<int>(local_expert_offset), kKimiNumExperts);
+  check_cuda_launch("kimi_k26_moe_gate_up_warp_decode_kernel");
+
+  dim3 down_grid(kDownCtasPerToken, num_tokens);
+  kimi_k26_moe_down_warp_decode_kernel<<<down_grid, kThreadsPerCta, 0, stream>>>(
+      reinterpret_cast<__nv_bfloat16 const*>(intermediate_tensor.data_ptr()),
+      static_cast<uint8_t const*>(gemm2_weights.data_ptr()),
+      reinterpret_cast<__nv_bfloat16 const*>(gemm2_weights_scale.data_ptr()),
+      static_cast<int32_t const*>(topk_ids.data_ptr()),
+      static_cast<float const*>(topk_weights.data_ptr()),
+      reinterpret_cast<__nv_bfloat16*>(output_ptr), num_tokens, kKimiTopK, kKimiHiddenSize,
+      kKimiK26IntermediateSize, static_cast<int>(local_expert_offset), kKimiNumExperts);
+  check_cuda_launch("kimi_k26_moe_down_warp_decode_kernel");
+
+  if (output.has_value()) {
+    return Array<Tensor>();
+  }
+  return {output_tensor};
+}
