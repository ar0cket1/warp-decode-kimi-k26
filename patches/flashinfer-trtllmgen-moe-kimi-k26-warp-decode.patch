+constexpr int kWarpSize = 32;
+constexpr int kWarpsPerCta = 8;
+constexpr int kThreadsPerCta = kWarpSize * kWarpsPerCta;
+constexpr int kKimiTopK = 8;
+constexpr int kMxInt4GroupSize = 32;
+constexpr int kKimiHiddenSize = 7168;
+// SGLang's Kimi K2.6 InferenceX-style serving path runs TP=8. The MoE
+// intermediate dimension is tensor-parallel sharded, so each rank owns 256
+// intermediate values per expert, then the hidden output is all-reduced.
+constexpr int kKimiK26IntermediateSize = 256;
+constexpr int kKimiNumExperts = 384;
+constexpr int kKimiPackedHiddenSize = kKimiHiddenSize / 2;
+constexpr int kKimiHiddenScaleGroups = kKimiHiddenSize / kMxInt4GroupSize;
+constexpr int kKimiPackedIntermediateSize = kKimiK26IntermediateSize / 2;
+constexpr int kKimiIntermediateScaleGroups = kKimiK26IntermediateSize / kMxInt4GroupSize;
+constexpr int kGateUpWarpsPerToken = kKimiTopK * kKimiK26IntermediateSize;
+constexpr int kGateUpCtasPerToken = kGateUpWarpsPerToken / kWarpsPerCta;
+constexpr int kDownWarpsPerToken = kKimiHiddenSize;
+constexpr int kDownCtasPerToken = kDownWarpsPerToken / kWarpsPerCta;
+constexpr int kDownOutputHiddenTile = 1;
+constexpr int kDownIntermediateTile = 256;
+constexpr int kDownIntermediateTiles = kKimiK26IntermediateSize / kDownIntermediateTile;
+constexpr int kDownExpertTileStrideBytes =
+    kDownOutputHiddenTile * (kDownIntermediateTile / 2);
+constexpr int kDownScaleGroupsPerTile = kDownIntermediateTile / kMxInt4GroupSize;
+static_assert(kKimiHiddenSize % kMxInt4GroupSize == 0,
+              "Kimi K2.6 hidden size must contain whole MxInt4 groups");
+static_assert(kKimiK26IntermediateSize % kMxInt4GroupSize == 0,
+              "Kimi K2.6 intermediate size must contain whole MxInt4 groups");
+static_assert(kGateUpWarpsPerToken % kWarpsPerCta == 0,
+              "gate/up grid must use whole CTAs per token");
+static_assert(kDownWarpsPerToken % kWarpsPerCta == 0,
+              "down grid must use whole CTAs per token");
+static_assert(kDownIntermediateTile % kMxInt4GroupSize == 0,
+              "down intermediate tile must be a multiple of the MxInt4 group size");
+static_assert(kDownExpertTileStrideBytes == 128,
+              "down expert tile payload must begin on 128-byte transaction boundaries");
+static_assert(kDownIntermediateTiles == 1,
+              "Kimi K2.6 TP=8 tiled down decode path expects exactly one K-tile");
+
+__device__ __forceinline__ float bf16_load(__nv_bfloat16 const* ptr, int64_t idx) {
+  return __bfloat162float(ptr[idx]);
+}
+
+__device__ __forceinline__ float routing_logit_load(void const* ptr, bool is_bf16,
+                                                    int64_t idx) {
+  if (is_bf16) {
+    return __bfloat162float(reinterpret_cast<__nv_bfloat16 const*>(ptr)[idx]);
+  }
+  return reinterpret_cast<float const*>(ptr)[idx];
+}
+
+__device__ __forceinline__ int8_t unpack_signed_int4(uint8_t packed, int k) {
+  int v = (k & 1) == 0 ? (packed & 0x0F) : ((packed >> 4) & 0x0F);
+  return static_cast<int8_t>(v >= 8 ? v - 16 : v);
+}
+
+__device__ __forceinline__ uint8_t load_packed_int4_pair_shared(uint8_t const* ptr,
+                                                               int logical_idx, int lane) {
+  int packed = 0;
+  if ((lane & 1) == 0) {
+    packed = static_cast<int>(ptr[logical_idx >> 1]);
+  }
+  packed = __shfl_sync(0xFFFFFFFFu, packed, lane & ~1);
+  return static_cast<uint8_t>(packed);
+}
+
+__device__ __forceinline__ int8_t load_signed_int4_pair_shared(uint8_t const* ptr,
+                                                              int logical_idx, int lane) {
+  uint8_t packed = load_packed_int4_pair_shared(ptr, logical_idx, lane);
+  return unpack_signed_int4(packed, logical_idx);
+}
+
+__device__ __forceinline__ float warp_sum(float x) {
+#pragma unroll
+  for (int mask = 16; mask > 0; mask >>= 1) {
+    x += __shfl_xor_sync(0xFFFFFFFFu, x, mask);
+  }
+  return x;
+}
+
+__device__ __forceinline__ float warp_broadcast_lane0(float x) {
+  return __shfl_sync(0xFFFFFFFFu, x, 0);
+}
+
+__device__ __forceinline__ int warp_broadcast_lane0(int x) {
+  return __shfl_sync(0xFFFFFFFFu, x, 0);
+}
+
+__device__ __forceinline__ void prefetch_global_l2(void const* ptr) {
+#if defined(__CUDA_ARCH__) && (__CUDA_ARCH__ >= 800)
+  unsigned long long addr = reinterpret_cast<unsigned long long>(ptr);
+  asm volatile("prefetch.global.L2 [%0];" : : "l"(addr));
+#else
+  (void)ptr;
+#endif
+}
+
+__device__ __forceinline__ float silu(float x) { return x / (1.0f + __expf(-x)); }
+
+struct RoutedTopK8 {
+  int expert0;
+  int expert1;
+  int expert2;
+  int expert3;
+  int expert4;
+  int expert5;
+  int expert6;
+  int expert7;
+  float weight0;
+  float weight1;
+  float weight2;
+  float weight3;
+  float weight4;
+  float weight5;
+  float weight6;
+  float weight7;
+};
+
+__device__ __forceinline__ RoutedTopK8 load_routed_topk8(
+    int32_t const* __restrict__ topk_ids, float const* __restrict__ topk_weights, int token,
+    int local_expert_offset, int lane) {
+  int64_t base = static_cast<int64_t>(token) * kKimiTopK;
+  RoutedTopK8 routes{};
+  if (lane == 0) {
+    routes.expert0 = topk_ids[base + 0] - local_expert_offset;
+    routes.expert1 = topk_ids[base + 1] - local_expert_offset;
+    routes.expert2 = topk_ids[base + 2] - local_expert_offset;
+    routes.expert3 = topk_ids[base + 3] - local_expert_offset;
+    routes.expert4 = topk_ids[base + 4] - local_expert_offset;
+    routes.expert5 = topk_ids[base + 5] - local_expert_offset;
+    routes.expert6 = topk_ids[base + 6] - local_expert_offset;
+    routes.expert7 = topk_ids[base + 7] - local_expert_offset;
+    routes.weight0 = topk_weights[base + 0];
+    routes.weight1 = topk_weights[base + 1];
+    routes.weight2 = topk_weights[base + 2];
+    routes.weight3 = topk_weights[base + 3];
+    routes.weight4 = topk_weights[base + 4];
+    routes.weight5 = topk_weights[base + 5];
+    routes.weight6 = topk_weights[base + 6];
+    routes.weight7 = topk_weights[base + 7];
+  }
+  routes.expert0 = warp_broadcast_lane0(routes.expert0);
+  routes.expert1 = warp_broadcast_lane0(routes.expert1);
+  routes.expert2 = warp_broadcast_lane0(routes.expert2);
+  routes.expert3 = warp_broadcast_lane0(routes.expert3);
+  routes.expert4 = warp_broadcast_lane0(routes.expert4);
+  routes.expert5 = warp_broadcast_lane0(routes.expert5);
+  routes.expert6 = warp_broadcast_lane0(routes.expert6);
+  routes.expert7 = warp_broadcast_lane0(routes.expert7);
+  routes.weight0 = warp_broadcast_lane0(routes.weight0);
+  routes.weight1 = warp_broadcast_lane0(routes.weight1);
+  routes.weight2 = warp_broadcast_lane0(routes.weight2);
+  routes.weight3 = warp_broadcast_lane0(routes.weight3);
+  routes.weight4 = warp_broadcast_lane0(routes.weight4);
+  routes.weight5 = warp_broadcast_lane0(routes.weight5);
+  routes.weight6 = warp_broadcast_lane0(routes.weight6);
+  routes.weight7 = warp_broadcast_lane0(routes.weight7);
+  return routes;
+}
+
+template <int Route>
+__device__ __forceinline__ int routed_expert(RoutedTopK8 const& routes) {
+  if (Route == 0) return routes.expert0;
+  if (Route == 1) return routes.expert1;
+  if (Route == 2) return routes.expert2;
+  if (Route == 3) return routes.expert3;
+  if (Route == 4) return routes.expert4;
+  if (Route == 5) return routes.expert5;
+  if (Route == 6) return routes.expert6;
+  return routes.expert7;
+}
+
+template <int Route>
+__device__ __forceinline__ float routed_weight(RoutedTopK8 const& routes) {
+  if (Route == 0) return routes.weight0;
+  if (Route == 1) return routes.weight1;
+  if (Route == 2) return routes.weight2;
+  if (Route == 3) return routes.weight3;
+  if (Route == 4) return routes.weight4;
+  if (Route == 5) return routes.weight5;
+  if (Route == 6) return routes.weight6;
+  return routes.weight7;
+}
+
+__global__ void kimi_k26_topk_deepseek_v3_kernel(
+    void const* __restrict__ routing_logits, bool routing_logits_is_bf16,
+    __nv_bfloat16 const* __restrict__ routing_bias, int32_t* __restrict__ topk_ids,
+    float* __restrict__ topk_weights, int num_tokens, int num_experts, int top_k,
+    float routed_scaling_factor) {
+  (void)num_experts;
+  (void)top_k;
+  int token = blockIdx.x * blockDim.x + threadIdx.x;
+  if (token >= num_tokens) {
+    return;
+  }
+
+  float best_vals[kKimiTopK];
+  int best_ids[kKimiTopK];
+#pragma unroll
+  for (int i = 0; i < kKimiTopK; ++i) {
+    best_vals[i] = -3.402823466e+38F;
+    best_ids[i] = -1;
+  }
+
+  for (int expert = 0; expert < kKimiNumExperts; ++expert) {
+    float logit =
+        routing_logit_load(routing_logits, routing_logits_is_bf16,
+                           static_cast<int64_t>(token) * kKimiNumExperts + expert);
+    float score = 1.0f / (1.0f + __expf(-logit));
+    float choice = score;
+    if (routing_bias != nullptr) {
+      choice += __bfloat162float(routing_bias[expert]);
+    }
+
+    int insert_at = -1;
+#pragma unroll
+    for (int i = 0; i < kKimiTopK; ++i) {
+      if (choice > best_vals[i]) {
+        insert_at = i;
+        break;
+      }
+    }
+    if (insert_at >= 0) {
+      for (int i = kKimiTopK - 1; i > insert_at; --i) {
+        best_vals[i] = best_vals[i - 1];
+        best_ids[i] = best_ids[i - 1];
+      }
+      best_vals[insert_at] = choice;
+      best_ids[insert_at] = expert;
+    }
+  }
+
+  float weight_sum = 0.0f;
+#pragma unroll
+  for (int i = 0; i < kKimiTopK; ++i) {
+    int expert = best_ids[i];
+    float logit =
+        routing_logit_load(routing_logits, routing_logits_is_bf16,
+                           static_cast<int64_t>(token) * kKimiNumExperts + expert);
+    float score = 1.0f / (1.0f + __expf(-logit));
+    topk_ids[static_cast<int64_t>(token) * kKimiTopK + i] = expert;
+    topk_weights[static_cast<int64_t>(token) * kKimiTopK + i] = score;
+    weight_sum += score;
+  }
+
+  float inv_sum = weight_sum > 0.0f ? routed_scaling_factor / weight_sum : 0.0f;
+#pragma unroll
+  for (int i = 0; i < kKimiTopK; ++i) {
+    topk_weights[static_cast<int64_t>(token) * kKimiTopK + i] *= inv_sum;
+  }
+}
+
+__global__ void kimi_k26_moe_gate_up_warp_decode_kernel(
+    __nv_bfloat16 const* __restrict__ hidden_states, uint8_t const* __restrict__ w13,
+    __nv_bfloat16 const* __restrict__ w13_scale, int32_t const* __restrict__ topk_ids,
+    __nv_bfloat16* __restrict__ intermediate, int num_tokens, int top_k, int hidden_size,
+    int intermediate_size, int local_expert_offset, int local_num_experts) {
+  (void)top_k;
+  (void)hidden_size;
+  (void)intermediate_size;
+  (void)local_num_experts;
+  int lane = threadIdx.x & (kWarpSize - 1);
+  int warp_in_cta = threadIdx.x >> 5;
+  int token = static_cast<int>(blockIdx.y);
+  if (token >= num_tokens) {
+    return;
+  }
+
+  int warp_in_token = static_cast<int>(blockIdx.x) * kWarpsPerCta + warp_in_cta;
+  int route = warp_in_token / kKimiK26IntermediateSize;
+  int neuron = warp_in_token - route * kKimiK26IntermediateSize;
+  int expert = topk_ids[static_cast<int64_t>(token) * kKimiTopK + route] - local_expert_offset;
+  if (expert < 0 || expert >= kKimiNumExperts) {
+    if (lane == 0) {
+      intermediate[(static_cast<int64_t>(token) * kKimiTopK + route) *
+                       kKimiK26IntermediateSize +
+                   neuron] =
+          __float2bfloat16_rn(0.0f);
+    }
+    return;
+  }
+
+  int gate_row = neuron;
+  int up_row = kKimiK26IntermediateSize + neuron;
+  int64_t expert_w13_base = static_cast<int64_t>(expert) * (2 * kKimiK26IntermediateSize) *
+                            kKimiPackedHiddenSize;
+  int64_t expert_scale_base = static_cast<int64_t>(expert) * (2 * kKimiK26IntermediateSize) *
+                              kKimiHiddenScaleGroups;
+  int64_t gate_row_base =
+      expert_w13_base + static_cast<int64_t>(gate_row) * kKimiPackedHiddenSize;
+  int64_t up_row_base = expert_w13_base + static_cast<int64_t>(up_row) * kKimiPackedHiddenSize;
+  int64_t gate_scale_row_base =
+      expert_scale_base + static_cast<int64_t>(gate_row) * kKimiHiddenScaleGroups;
+  int64_t up_scale_row_base =
+      expert_scale_base + static_cast<int64_t>(up_row) * kKimiHiddenScaleGroups;
+  int64_t token_base = static_cast<int64_t>(token) * kKimiHiddenSize;
+  float gate_acc = 0.0f;
+  float up_acc = 0.0f;
+
+  for (int group = 0; group < kKimiHiddenScaleGroups; ++group) {
+    int h = group * kMxInt4GroupSize + lane;
+    float x = bf16_load(hidden_states, token_base + h);
+    int8_t gate_w = load_signed_int4_pair_shared(w13 + gate_row_base, h, lane);
+    int8_t up_w = load_signed_int4_pair_shared(w13 + up_row_base, h, lane);
+    float gate_scale = 0.0f;
+    float up_scale = 0.0f;
+    if (lane == 0) {
+      gate_scale = bf16_load(w13_scale, gate_scale_row_base + group);
+      up_scale = bf16_load(w13_scale, up_scale_row_base + group);
+    }
+    gate_scale = warp_broadcast_lane0(gate_scale);
+    up_scale = warp_broadcast_lane0(up_scale);
+    gate_acc += x * static_cast<float>(gate_w) * gate_scale;
+    up_acc += x * static_cast<float>(up_w) * up_scale;
+  }
+
+  gate_acc = warp_sum(gate_acc);
+  up_acc = warp_sum(up_acc);
+  if (lane == 0) {
+    float y = silu(gate_acc) * up_acc;
+    intermediate[(static_cast<int64_t>(token) * kKimiTopK + route) *
+                     kKimiK26IntermediateSize +
+                 neuron] = __float2bfloat16_rn(y);
+  }
+}
+
+template <int Route>
+__device__ __forceinline__ void accumulate_row_major_down_route(
+    __nv_bfloat16 const* __restrict__ intermediate, uint8_t const* __restrict__ w2,
+    __nv_bfloat16 const* __restrict__ w2_scale, RoutedTopK8 const& routes, int token, int lane,
+    int hidden_dim, float& acc) {
+  int expert = routed_expert<Route>(routes);
+  if (expert < 0 || expert >= kKimiNumExperts) {
+    return;
+  }
+
+  float route_weight = routed_weight<Route>(routes);
+  int64_t expert_w2_base =
+      static_cast<int64_t>(expert) * kKimiHiddenSize * kKimiPackedIntermediateSize;
+  int64_t expert_scale_base =
+      static_cast<int64_t>(expert) * kKimiHiddenSize * kKimiIntermediateScaleGroups;
+  int64_t interm_base =
+      (static_cast<int64_t>(token) * kKimiTopK + Route) * kKimiK26IntermediateSize;
+  int64_t w2_row_base =
+      expert_w2_base + static_cast<int64_t>(hidden_dim) * kKimiPackedIntermediateSize;
+  int64_t scale_row_base = expert_scale_base +
+                           static_cast<int64_t>(hidden_dim) * kKimiIntermediateScaleGroups;
+
+#pragma unroll
+  for (int group = 0; group < kKimiIntermediateScaleGroups; ++group) {
+    int j = group * kMxInt4GroupSize + lane;
+    float x = bf16_load(intermediate, interm_base + j);
+    int8_t w = load_signed_int4_pair_shared(w2 + w2_row_base, j, lane);
+    float scale = 0.0f;
+    if (lane == 0) {
+      scale = bf16_load(w2_scale, scale_row_base + group);
+    }
+    scale = warp_broadcast_lane0(scale);
+    acc += route_weight * x * static_cast<float>(w) * scale;
+  }
+}
+
+__device__ __forceinline__ void accumulate_row_major_down_routes(
+    __nv_bfloat16 const* __restrict__ intermediate, uint8_t const* __restrict__ w2,
+    __nv_bfloat16 const* __restrict__ w2_scale, RoutedTopK8 const& routes, int token, int lane,
+    int hidden_dim, float& acc) {
+  accumulate_row_major_down_route<0>(intermediate, w2, w2_scale, routes, token, lane, hidden_dim,
+                                     acc);
+  accumulate_row_major_down_route<1>(intermediate, w2, w2_scale, routes, token, lane, hidden_dim,
+                                     acc);
+  accumulate_row_major_down_route<2>(intermediate, w2, w2_scale, routes, token, lane, hidden_dim,
+                                     acc);
+  accumulate_row_major_down_route<3>(intermediate, w2, w2_scale, routes, token, lane, hidden_dim,
+                                     acc);
+  accumulate_row_major_down_route<4>(intermediate, w2, w2_scale, routes, token, lane, hidden_dim,
+                                     acc);
+  accumulate_row_major_down_route<5>(intermediate, w2, w2_scale, routes, token, lane, hidden_dim,
+                                     acc);
+  accumulate_row_major_down_route<6>(intermediate, w2, w2_scale, routes, token, lane, hidden_dim,
+                                     acc);
+  accumulate_row_major_down_route<7>(intermediate, w2, w2_scale, routes, token, lane, hidden_dim,
+                                     acc);
+}
+
+__global__ void kimi_k26_moe_down_warp_decode_kernel(
+    __nv_bfloat16 const* __restrict__ intermediate, uint8_t const* __restrict__ w2,
+    __nv_bfloat16 const* __restrict__ w2_scale, int32_t const* __restrict__ topk_ids,
+    float const* __restrict__ topk_weights, __nv_bfloat16* __restrict__ output, int num_tokens,
+    int top_k, int hidden_size, int intermediate_size, int local_expert_offset,
+    int local_num_experts) {
+  (void)top_k;
+  (void)hidden_size;
+  (void)intermediate_size;
+  (void)local_num_experts;
+  int lane = threadIdx.x & (kWarpSize - 1);
+  int warp_in_cta = threadIdx.x >> 5;
+  int token = static_cast<int>(blockIdx.y);
+  if (token >= num_tokens) {
+    return;
+  }
+
+  int hidden_dim = static_cast<int>(blockIdx.x) * kWarpsPerCta + warp_in_cta;
+  RoutedTopK8 routes =
+      load_routed_topk8(topk_ids, topk_weights, token, local_expert_offset, lane);
+  float acc = 0.0f;
+
+  accumulate_row_major_down_routes(intermediate, w2, w2_scale, routes, token, lane, hidden_dim,
+                                   acc);
+
+  acc = warp_sum(acc);
+  if (lane == 0) {
+    output[static_cast<int64_t>(token) * kKimiHiddenSize + hidden_dim] =
+        __float2bfloat16_rn(acc);
+  }
+}
+
+template <int Route>
+__device__ __forceinline__ void prefetch_tiled_down_route(
+    uint8_t const* __restrict__ w2_tiled, __nv_bfloat16 const* __restrict__ w2_scale_tiled,
+    RoutedTopK8 const& routes, int lane, int64_t tile_group_base, int64_t scale_group_base) {
+  if (lane != 0) {
+    return;
+  }
+  int expert = routed_expert<Route>(routes);
+  if (expert >= 0 && expert < kKimiNumExperts) {
+    prefetch_global_l2(w2_tiled + tile_group_base +
+                       static_cast<int64_t>(expert) * kDownExpertTileStrideBytes);
+    prefetch_global_l2(w2_scale_tiled + scale_group_base +
+                       static_cast<int64_t>(expert) * kDownScaleGroupsPerTile);
+  }
+}
+
+template <int Route>
+__device__ __forceinline__ void accumulate_tiled_down_route(
+    __nv_bfloat16 const* __restrict__ intermediate, uint8_t const* __restrict__ w2_tiled,
+    __nv_bfloat16 const* __restrict__ w2_scale_tiled, RoutedTopK8 const& routes, int token,
+    int lane, int tile_id, int64_t tile_group_base, int64_t scale_group_base, float& acc) {
+  int expert = routed_expert<Route>(routes);
+  if (expert < 0 || expert >= kKimiNumExperts) {
+    return;
+  }
+
+  float route_weight = routed_weight<Route>(routes);
+  int tile_start = tile_id * kDownIntermediateTile;
+  int64_t interm_base =
+      (static_cast<int64_t>(token) * kKimiTopK + Route) * kKimiK26IntermediateSize + tile_start;
+  uint8_t const* tile_ptr =
+      w2_tiled + tile_group_base + static_cast<int64_t>(expert) * kDownExpertTileStrideBytes;
+  int64_t expert_scale_base =
+      scale_group_base + static_cast<int64_t>(expert) * kDownScaleGroupsPerTile;
+
+#pragma unroll
+  for (int group = 0; group < kDownScaleGroupsPerTile; ++group) {
+    int local_j = group * kMxInt4GroupSize + lane;
+    float x = bf16_load(intermediate, interm_base + local_j);
+    int8_t w = load_signed_int4_pair_shared(tile_ptr, local_j, lane);
+    float scale = 0.0f;
+    if (lane == 0) {
+      scale = bf16_load(w2_scale_tiled, expert_scale_base + group);
+    }
+    scale = warp_broadcast_lane0(scale);
+    acc += route_weight * x * static_cast<float>(w) * scale;
+  }
+}
+
+__device__ __forceinline__ int64_t tiled_down_tile_group_base(int output_hidden_tile,
+                                                             int tile_id) {
+  return (static_cast<int64_t>(output_hidden_tile) * kDownIntermediateTiles + tile_id) *
+         kKimiNumExperts * kDownExpertTileStrideBytes;
+}
+
+__device__ __forceinline__ int64_t tiled_down_scale_group_base(int output_hidden_tile,
+                                                              int tile_id) {
+  return (static_cast<int64_t>(output_hidden_tile) * kDownIntermediateTiles + tile_id) *
+         kKimiNumExperts * kDownScaleGroupsPerTile;
+}
+
+__device__ __forceinline__ void prefetch_tiled_down_routes(
+    uint8_t const* __restrict__ w2_tiled, __nv_bfloat16 const* __restrict__ w2_scale_tiled,
+    RoutedTopK8 const& routes, int lane, int64_t tile_group_base, int64_t scale_group_base) {
+  // W_down scales are a sidecar tensor, not inline with the 128B INT4 payload.
+  prefetch_tiled_down_route<0>(w2_tiled, w2_scale_tiled, routes, lane, tile_group_base,
+                               scale_group_base);
+  prefetch_tiled_down_route<1>(w2_tiled, w2_scale_tiled, routes, lane, tile_group_base,
+                               scale_group_base);
+  prefetch_tiled_down_route<2>(w2_tiled, w2_scale_tiled, routes, lane, tile_group_base,
+                               scale_group_base);
+  prefetch_tiled_down_route<3>(w2_tiled, w2_scale_tiled, routes, lane, tile_group_base,
+                               scale_group_base);
+  prefetch_tiled_down_route<4>(w2_tiled, w2_scale_tiled, routes, lane, tile_group_base,
+                               scale_group_base);
+  prefetch_tiled_down_route<5>(w2_tiled, w2_scale_tiled, routes, lane, tile_group_base,
+                               scale_group_base);
+  prefetch_tiled_down_route<6>(w2_tiled, w2_scale_tiled, routes, lane, tile_group_base,
+                               scale_group_base);
+  prefetch_tiled_down_route<7>(w2_tiled, w2_scale_tiled, routes, lane, tile_group_base,
+                               scale_group_base);
+}
+
+__device__ __forceinline__ void accumulate_tiled_down_routes(
+    __nv_bfloat16 const* __restrict__ intermediate, uint8_t const* __restrict__ w2_tiled,
+    __nv_bfloat16 const* __restrict__ w2_scale_tiled, RoutedTopK8 const& routes, int token,
+    int lane, int tile_id, int64_t tile_group_base, int64_t scale_group_base, float& acc) {
+  accumulate_tiled_down_route<0>(intermediate, w2_tiled, w2_scale_tiled, routes, token, lane,
+                                 tile_id, tile_group_base, scale_group_base, acc);
+  accumulate_tiled_down_route<1>(intermediate, w2_tiled, w2_scale_tiled, routes, token, lane,
+                                 tile_id, tile_group_base, scale_group_base, acc);
+  accumulate_tiled_down_route<2>(intermediate, w2_tiled, w2_scale_tiled, routes, token, lane,
+                                 tile_id, tile_group_base, scale_group_base, acc);
+  accumulate_tiled_down_route<3>(intermediate, w2_tiled, w2_scale_tiled, routes, token, lane,
+                                 tile_id, tile_group_base, scale_group_base, acc);
+  accumulate_tiled_down_route<4>(intermediate, w2_tiled, w2_scale_tiled, routes, token, lane,
+                                 tile_id, tile_group_base, scale_group_base, acc);
+  accumulate_tiled_down_route<5>(intermediate, w2_tiled, w2_scale_tiled, routes, token, lane,
+                                 tile_id, tile_group_base, scale_group_base, acc);
+  accumulate_tiled_down_route<6>(intermediate, w2_tiled, w2_scale_tiled, routes, token, lane,
+                                 tile_id, tile_group_base, scale_group_base, acc);
+  accumulate_tiled_down_route<7>(intermediate, w2_tiled, w2_scale_tiled, routes, token, lane,
+                                 tile_id, tile_group_base, scale_group_base, acc);
+}
+
+__global__ void kimi_k26_moe_down_warp_decode_tiled_kernel(
+    __nv_bfloat16 const* __restrict__ intermediate, uint8_t const* __restrict__ w2_tiled,
+    __nv_bfloat16 const* __restrict__ w2_scale_tiled, int32_t const* __restrict__ topk_ids,
+    float const* __restrict__ topk_weights, __nv_bfloat16* __restrict__ output, int num_tokens,
+    int top_k, int hidden_size, int intermediate_size, int local_expert_offset,
+    int local_num_experts) {
+  (void)top_k;
+  (void)hidden_size;
+  (void)intermediate_size;
+  (void)local_num_experts;
+  int lane = threadIdx.x & (kWarpSize - 1);
+  int warp_in_cta = threadIdx.x >> 5;
+  int token = static_cast<int>(blockIdx.y);
+  if (token >= num_tokens) {
+    return;
+  }
+
+  int hidden_dim = static_cast<int>(blockIdx.x) * kWarpsPerCta + warp_in_cta;
+  int output_hidden_tile = hidden_dim;
+  RoutedTopK8 routes =
+      load_routed_topk8(topk_ids, topk_weights, token, local_expert_offset, lane);
+  float acc = 0.0f;
+
+  prefetch_tiled_down_routes(
+      w2_tiled, w2_scale_tiled, routes, lane,
+      tiled_down_tile_group_base(output_hidden_tile, 0),
+      tiled_down_scale_group_base(output_hidden_tile, 0));
+
+#pragma unroll 1
+  for (int tile_id = 0; tile_id < kDownIntermediateTiles; ++tile_id) {
+    int64_t tile_group_base = tiled_down_tile_group_base(output_hidden_tile, tile_id);
+    int64_t scale_group_base = tiled_down_scale_group_base(output_hidden_tile, tile_id);
+
+    if (tile_id + 1 < kDownIntermediateTiles) {
+      prefetch_tiled_down_routes(
+          w2_tiled, w2_scale_tiled, routes, lane,
+          tiled_down_tile_group_base(output_hidden_tile, tile_id + 1),
+          tiled_down_scale_group_base(output_hidden_tile, tile_id + 1));
+    }
+
+    accumulate_tiled_down_routes(intermediate, w2_tiled, w2_scale_tiled, routes, token, lane,
+                                 tile_id, tile_group_base, scale_group_base, acc);
+  }
+
+  acc = warp_sum(acc);
+  if (lane == 0) {
+    output[static_cast<int64_t>(token) * kKimiHiddenSize + hidden_dim] =
+        __float2bfloat16_rn(acc);
+  }
+}
